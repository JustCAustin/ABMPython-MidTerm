import base64
import hashlib
import json
import os
import time
import uuid

try:
    from cryptography.fernet import Fernet
    HAVE_FERNET = True
except ImportError:
    HAVE_FERNET = False


class KeyVault:

    def __init__(self):
        if HAVE_FERNET:
            self.cipher_key = Fernet.generate_key()
            self._cipher = Fernet(self.cipher_key)
        else:
            self.cipher_key = os.urandom(16)

    def encrypt(self, plaintext: str) -> bytes:
        if HAVE_FERNET:
            return self._cipher.encrypt(plaintext.encode())
        data = plaintext.encode()
        xored = bytes(b ^ self.cipher_key[i % len(self.cipher_key)] for i, b in enumerate(data))
        return base64.b64encode(xored)

    def decrypt(self, token: bytes) -> str:
        if HAVE_FERNET:
            return self._cipher.decrypt(token).decode()
        raw = base64.b64decode(token)
        xored = bytes(b ^ self.cipher_key[i % len(self.cipher_key)] for i, b in enumerate(raw))
        return xored.decode()


def sha256_hash(data: str) -> str:
    return hashlib.sha256(data.encode()).hexdigest()


class Wallet:
    def __init__(self, owner):
        self.owner = owner
        self.vault = KeyVault()
        private_key_plain = uuid.uuid4().hex + uuid.uuid4().hex
        self.encrypted_private_key = self.vault.encrypt(private_key_plain)
        self.address = "0x" + sha256_hash(private_key_plain)[:24]
        self.balance = 0.0

    def reveal_private_key(self):
        return self.vault.decrypt(self.encrypted_private_key)

    def __str__(self):
        return f"Wallet[{self.owner}] address={self.address} balance={self.balance:.4f} BTC"


class Transaction:
    def __init__(self, sender, recipient, amount):
        self.tx_id = str(uuid.uuid4())[:10]
        self.sender = sender        
        self.recipient = recipient  
        self.amount = amount
        self.timestamp = time.time()

    def to_dict(self):
        return {"tx_id": self.tx_id, "sender": self.sender, "recipient": self.recipient,
                 "amount": self.amount, "timestamp": self.timestamp}

    def __str__(self):
        return f"TX[{self.tx_id}] {self.sender[:10]}.. -> {self.recipient[:10]}.. : {self.amount} BTC"


class Block:
    def __init__(self, index, transactions, previous_hash, nonce=0):
        self.index = index
        self.transactions = transactions
        self.previous_hash = previous_hash
        self.nonce = nonce
        self.timestamp = time.time()
        self.hash = self.compute_hash()

    def compute_hash(self):
        block_string = json.dumps({
            "index": self.index,
            "transactions": [t.to_dict() for t in self.transactions],
            "previous_hash": self.previous_hash,
            "nonce": self.nonce,
            "timestamp": self.timestamp,
        }, sort_keys=True)
        return sha256_hash(block_string)


class Blockchain:

    DIFFICULTY_PREFIX = "0" * 3
    MINING_REWARD = 6.25

    def __init__(self):
        self.chain = [self._genesis_block()]
        self.pending_transactions = []
        self.wallets = {}  

    def _genesis_block(self):
        return Block(0, [], previous_hash="0" * 64)

    def register_wallet(self, wallet: Wallet):
        self.wallets[wallet.address] = wallet

    def get_balance(self, address):
        return self.wallets[address].balance if address in self.wallets else 0.0

    def validate_transaction(self, tx: Transaction):
        if tx.amount <= 0:
            return False, "Amount must be positive."
        if tx.sender != "NETWORK":
            if tx.sender not in self.wallets:
                return False, "Unknown sender wallet."
            if self.wallets[tx.sender].balance < tx.amount:
                return False, "Insufficient balance."
        if tx.recipient not in self.wallets:
            return False, "Unknown recipient wallet."
        return True, "OK"

    def submit_transaction(self, tx: Transaction):
        valid, reason = self.validate_transaction(tx)
        if not valid:
            print(f"  [REJECTED] {tx} -> {reason}")
            return False
        self.pending_transactions.append(tx)
        print(f"  [QUEUED] {tx}")
        return True

    def mine_pending_transactions(self, miner_address):
        """Proof-of-work: find a nonce so the block's hash starts with
        the required number of leading zeros."""
        reward_tx = Transaction("NETWORK", miner_address, self.MINING_REWARD)
        block_transactions = self.pending_transactions + [reward_tx]
        previous_hash = self.chain[-1].hash

        nonce = 0
        start = time.time()
        while True:
            candidate = Block(len(self.chain), block_transactions, previous_hash, nonce)
            if candidate.hash.startswith(self.DIFFICULTY_PREFIX):
                break
            nonce += 1
        elapsed = time.time() - start

        for tx in block_transactions:
            if tx.sender != "NETWORK":
                self.wallets[tx.sender].balance -= tx.amount
            self.wallets[tx.recipient].balance += tx.amount

        self.chain.append(candidate)
        self.pending_transactions = []
        print(f"  Block #{candidate.index} mined in {elapsed:.3f}s (nonce={nonce}) "
              f"hash={candidate.hash[:16]}...")
        return candidate

    def is_chain_valid(self):
        for i in range(1, len(self.chain)):
            current, previous = self.chain[i], self.chain[i - 1]
            if current.hash != current.compute_hash():
                return False, f"Block {i} hash mismatch (tampered data)."
            if current.previous_hash != previous.hash:
                return False, f"Block {i} previous_hash link broken."
        return True, "Chain is valid."


def demo():
    chain = Blockchain()

    alice = Wallet("Alice")
    bob = Wallet("Bob")
    miner = Wallet("MinerCorp")
    for w in (alice, bob, miner):
        chain.register_wallet(w)
        print(w)

    print(f"\nAlice's decrypted private key (only she can reveal it): {alice.reveal_private_key()[:16]}...")

    print("\n=== Mining genesis funds for Alice ===")
    chain.submit_transaction(Transaction("NETWORK", alice.address, 50.0))
    chain.mine_pending_transactions(miner.address)

    print(f"\nAlice balance: {chain.get_balance(alice.address)}")
    print(f"Miner balance (mining reward): {chain.get_balance(miner.address)}")

    print("\n=== Alice sends 10 BTC to Bob ===")
    chain.submit_transaction(Transaction(alice.address, bob.address, 10.0))
    print("\n=== Alice tries to overspend (should be rejected) ===")
    chain.submit_transaction(Transaction(alice.address, bob.address, 1000.0))
    chain.mine_pending_transactions(miner.address)

    print(f"\nFinal balances:")
    print(f"  Alice: {chain.get_balance(alice.address)}")
    print(f"  Bob:   {chain.get_balance(bob.address)}")
    print(f"  Miner: {chain.get_balance(miner.address)}")

    print("\n=== Chain validation ===")
    valid, msg = chain.is_chain_valid()
    print(f"  {msg}")

    print("\n=== Tampering with block 1 to demonstrate hash detection ===")
    chain.chain[1].transactions[0].amount = 9999.0  
    valid, msg = chain.is_chain_valid()
    print(f"  {msg}")


if __name__ == "__main__":
    demo()
